{
  "name": "adb-mcp",
  "version": "0.1.1",
  "description": "MCP server for Android Debug Bridge (ADB) interactions in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "adb-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc -w",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:integration": "ts-node test/test-client.ts"
  },
  "keywords": [
    "mcp",
    "adb",
    "android",
    "llm",
    "typescript",
    "mcp server"
  ],
  "author": "Martin Arellano <llano.mga@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/srmorete/adb-mcp.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "fast-xml-parser": "^5.5.9",
    "sharp": "^0.34.5",
    "zod": "^3.21.4"
  },
  "directories": {
    "doc": "docs"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
